# Copy this file to .env.local (gitignored) and fill in values for local dev.

# ─── JWT / Auth ───────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXP_MINUTES=60

# ─── Google OAuth (optional for local dev) ────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OIDC_JWKS_URL=https://www.googleapis.com/oauth2/v3/certs
GOOGLE_OIDC_ALGORITHM=RS256

# ─── Database ─────────────────────────────────────────────────────────────────
# Docker Compose service name: postgres
DATABASE_URL=postgresql+asyncpg://ilm:ilm@postgres:5432/ilm

# ─── S3 / MinIO (local) ───────────────────────────────────────────────────────
# Set S3_ENDPOINT_URL="" or omit for real AWS S3
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=ilm-assignments

# ─── Provider selections ──────────────────────────────────────────────────────
# EMAIL_PROVIDER: console | ses
EMAIL_PROVIDER=console

# JOB_PROVIDER: background_tasks | sqs
JOB_PROVIDER=background_tasks

# NOTIFICATION_PROVIDER: console | fcm_apns
NOTIFICATION_PROVIDER=console
